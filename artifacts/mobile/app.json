{
  "expo": {
    "name": "bee",
    "slug": "bee",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bee",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4A7C59"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bee.app"
    },
    "android": {
      "backgroundColor": "#4A7C59",
      "package": "com.bee.app"
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "bundler": "metro",
      "output": "static",
      "name": "Bee",
      "shortName": "Bee",
      "description": "AI-powered food tracking. Snap a photo, get instant nutrition breakdown.",
      "themeColor": "#4A7C59",
      "backgroundColor": "#F5EFE6"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-image-picker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
